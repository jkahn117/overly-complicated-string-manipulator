---
---

<section
  x-data="{ tab: 'result' }"
  class="rounded-lg border border-border bg-surface shadow-sm"
>
  <!-- Tab bar -->
  <div class="flex border-b border-border">
    <button
      type="button"
      x-on:click="tab = 'result'"
      x-bind:class="tab === 'result' ? 'border-primary text-primary' : 'border-transparent text-text-muted hover:text-text'"
      class="border-b-2 px-4 py-2 text-xs font-medium transition-colors"
    >
      Output
    </button>
    <button
      type="button"
      x-on:click="tab = 'code'"
      x-bind:class="tab === 'code' ? 'border-primary text-primary' : 'border-transparent text-text-muted hover:text-text'"
      x-show="$store.pipeline.result?.generatedCode"
      class="border-b-2 px-4 py-2 text-xs font-medium transition-colors"
    >
      Generated Code
    </button>
  </div>

  <div class="p-4">
    <!-- ===== Result tab ===== -->
    <div x-show="tab === 'result'">
      <!-- Empty state -->
      <div
        x-show="!$store.pipeline.result && !$store.pipeline.error && !$store.pipeline.loading"
        class="py-6 text-center text-sm text-text-muted"
      >
        Run the pipeline to see results.
      </div>

      <!-- Loading state -->
      <div
        x-show="$store.pipeline.loading"
        x-cloak
        class="flex items-center justify-center gap-2 py-6 text-sm text-text-muted"
      >
        <svg class="h-4 w-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Running pipeline...
      </div>

      <!-- Success result -->
      <div x-show="$store.pipeline.result" x-cloak>
        <!-- Final output -->
        <div class="mb-4 rounded-md border border-success/30 bg-success/5 px-3 py-2">
          <span class="mb-1 block text-xs font-medium text-success">Result</span>
          <pre
            class="font-mono text-sm text-text"
            x-text="$store.pipeline.result?.data"
          ></pre>
        </div>

        <!-- History -->
        <div x-show="$store.pipeline.result?.history?.length > 0">
          <h3 class="mb-2 text-xs font-medium text-text-muted uppercase tracking-wide">
            Step History
          </h3>
          <div class="space-y-1.5">
            <template x-for="entry in $store.pipeline.result?.history" :key="entry.step">
              <div class="rounded border border-border bg-surface-alt px-3 py-2">
                <div class="flex items-center gap-2">
                  <span
                    class="flex h-4 w-4 items-center justify-center rounded-full bg-text-muted text-[9px] font-bold text-white"
                    x-text="entry.step + 1"
                  ></span>
                  <span class="font-mono text-xs font-semibold text-text" x-text="entry.op"></span>
                </div>
                <div class="mt-1 font-mono text-xs text-text-muted">
                  <span class="text-text" x-text="JSON.stringify(entry.input)"></span>
                  <span class="mx-1">&rarr;</span>
                  <span class="text-text" x-text="JSON.stringify(entry.output)"></span>
                </div>
              </div>
            </template>
          </div>
        </div>
      </div>

      <!-- Error state -->
      <div x-show="$store.pipeline.error" x-cloak>
        <div class="mb-4 rounded-md border border-danger/30 bg-danger/5 px-3 py-2">
          <span class="mb-1 block text-xs font-medium text-danger">Error</span>
          <pre
            class="font-mono text-sm text-text"
            x-text="$store.pipeline.error?.error"
          ></pre>
        </div>

        <!-- Partial history on error -->
        <div x-show="$store.pipeline.error?.history?.length > 0">
          <h3 class="mb-2 text-xs font-medium text-text-muted uppercase tracking-wide">
            Partial History
          </h3>
          <div class="space-y-1.5">
            <template x-for="entry in $store.pipeline.error?.history" :key="entry.step">
              <div class="rounded border border-border bg-surface-alt px-3 py-2">
                <div class="flex items-center gap-2">
                  <span
                    class="flex h-4 w-4 items-center justify-center rounded-full bg-text-muted text-[9px] font-bold text-white"
                    x-text="entry.step + 1"
                  ></span>
                  <span class="font-mono text-xs font-semibold text-text" x-text="entry.op"></span>
                </div>
                <div class="mt-1 font-mono text-xs text-text-muted">
                  <span class="text-text" x-text="JSON.stringify(entry.input)"></span>
                  <span class="mx-1">&rarr;</span>
                  <span class="text-text" x-text="JSON.stringify(entry.output)"></span>
                </div>
              </div>
            </template>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== Generated Code tab ===== -->
    <div x-show="tab === 'code'" x-cloak>
      <div class="relative">
        <pre class="max-h-96 overflow-auto rounded-md bg-slate-900 p-4 font-mono text-xs leading-relaxed text-slate-100"><code x-text="$store.pipeline.result?.generatedCode"></code></pre>
        <!-- Copy button -->
        <button
          type="button"
          x-data="{ copied: false }"
          x-on:click="navigator.clipboard.writeText($store.pipeline.result?.generatedCode ?? ''); copied = true; setTimeout(() => copied = false, 1500)"
          class="absolute top-2 right-2 rounded bg-slate-700 px-2 py-1 text-[10px] font-medium text-slate-300 transition-colors hover:bg-slate-600"
          x-text="copied ? 'Copied!' : 'Copy'"
        ></button>
      </div>
      <p class="mt-2 text-xs text-text-muted">
        This is the JavaScript Worker module generated from your pipeline steps, executed in a sandboxed isolate via Dynamic Worker Loader.
      </p>
    </div>
  </div>
</section>
