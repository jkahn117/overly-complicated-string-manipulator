---
---

<header class="border-b border-primary/20 bg-primary/5 px-4 py-4">
  <div class="mx-auto flex max-w-2xl items-end justify-between gap-4">
    <div>
      <h1 class="text-lg font-bold tracking-tight text-text">
        Overly complicated string manipulator
      </h1>
      <p class="mt-0.5 text-xs text-text-muted">
        A demo of Workers for Platforms and Dynamic Worker Loader
      </p>
    </div>
    <div class="flex shrink-0 flex-col items-end gap-1.5">
      <a
        href="https://github.com/jkahn117/overly-complicated-string-manipulator"
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-muted transition-colors hover:text-text"
        title="View on GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <div class="flex items-center gap-2">
        <label for="tenant-id" class="text-xs font-medium text-text-muted">Tenant</label>
        <input
          id="tenant-id"
          type="text"
          x-model="$store.pipeline.tenantId"
          x-on:change="$store.pipeline.setTenantId($store.pipeline.tenantId)"
          placeholder="playground"
          class="w-40 rounded border border-primary/20 bg-white px-2 py-1 font-mono text-xs text-text placeholder:text-text-muted focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none"
        />
      </div>
    </div>
  </div>
</header>
