---
---

<header class="border-b border-primary/20 bg-primary/5 px-4 py-4">
  <div class="mx-auto flex max-w-2xl items-end justify-between gap-4">
    <div>
      <h1 class="text-lg font-bold tracking-tight text-text">
        Overly complicated string manipulator
      </h1>
      <p class="mt-0.5 text-xs text-text-muted">
        A demo of Workers for Platforms and Dynamic Worker Loader
      </p>
    </div>
    <div class="flex shrink-0 items-center gap-2">
      <label for="tenant-id" class="text-xs font-medium text-text-muted">Tenant</label>
      <input
        id="tenant-id"
        type="text"
        x-model="$store.pipeline.tenantId"
        x-on:change="$store.pipeline.setTenantId($store.pipeline.tenantId)"
        placeholder="playground"
        class="w-40 rounded border border-primary/20 bg-white px-2 py-1 font-mono text-xs text-text placeholder:text-text-muted focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none"
      />
    </div>
  </div>
</header>
