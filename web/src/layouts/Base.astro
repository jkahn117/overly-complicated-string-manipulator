---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body x-data class="min-h-screen bg-surface-alt text-text antialiased">
    <slot name="header" />
    <div class="mx-auto max-w-2xl px-4 py-8">
      <slot />
    </div>
    <script>
      import Alpine from "alpinejs";
      import { registerStore } from "../scripts/pipeline";

      registerStore(Alpine);
      Alpine.start();
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
