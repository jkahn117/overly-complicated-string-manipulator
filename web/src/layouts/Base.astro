---
interface Props {
  title: string;
  wide?: boolean;
}

const { title, wide = false } = Astro.props;
const maxWidth = wide ? "max-w-4xl" : "max-w-2xl";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body x-data class="min-h-screen bg-surface-alt text-text antialiased">
    <slot name="header" />
    <div class:list={["mx-auto px-4 py-8", maxWidth]}>
      <slot />
    </div>
    <script>
      import Alpine from "alpinejs";
      import { registerStore } from "../scripts/pipeline";
      import { registerUsageData } from "../scripts/usage";

      registerStore(Alpine);
      registerUsageData(Alpine);
      Alpine.start();
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
